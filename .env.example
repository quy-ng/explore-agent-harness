# Default local model. The worker normalizes this to LiteLLM's
# provider-qualified name `ollama/qwen3:32b` when LITELLM_API_BASE
# points at localhost:11436.
MSWEA_MODEL_NAME=qwen3:32b

# Local Ollama-compatible server.
LITELLM_API_BASE=http://localhost:11436

# Local Ollama models often report zero cost through LiteLLM, which mini-SWE-agent
# treats as an error unless this is relaxed.
MSWEA_COST_TRACKING=ignore_errors
MSWEA_TRAJECTORY_PATH=trajectories/last_run.traj.json

# Set the provider key required by your LiteLLM model choice if you
# switch away from local Ollama.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
